{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        "npm install -g pnpm@11.1.3",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["pnpm build"]
    }
  },
  "deploy": {
    "startCommand": "pnpm start -p $PORT"
  }
}
